# ── BASE DE DADOS (Local) ──
# DATABASE_URL="postgresql://johndoe:randompassword@localhost:5432/mydb?schema=public"

# ── BASE DE DADOS (Supabase) ──

# Connect to Supabase via connection pooling
# Mude a porta de 6543 para 5432 para fazer o pull das migrations
DATABASE_URL="postgresql://postgres:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true"

# Direct connection to the database. Used for migrations
DIRECT_URL="postgresql://postgres:[YOUR-PASSWORD]@db.nfwqnwglmlhtbaiurhuc.supabase.co:5432/postgres"

# ── NEXTAUTH ──
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="[resultado do openssl rand -base64 32]"

# ── 42 INTRA API ──
FORTY_TWO_CLIENT_ID="[o teu client_id da 42 Intra]"
FORTY_TWO_CLIENT_SECRET="[o teu client_secret da 42 Intra]"
FORTY_TWO_CAMPUS_ID="[ID do campus 42 Luanda — confirmar com staff]"

# ── PUSHER (configurar na Fase 2) ──
PUSHER_APP_ID=""
NEXT_PUBLIC_PUSHER_KEY=""
PUSHER_SECRET=""
NEXT_PUBLIC_PUSHER_CLUSTER="eu"

# ── UPSTASH REDIS (configurar na Fase 2) ──
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# ── RESEND EMAIL (configurar na Fase 4) ──
RESEND_API_KEY=""

# ── CLOUDINARY (configurar na Fase 4) ──
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""